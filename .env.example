# Copy to .env for local development. `make dev` / `make import` source this.
# All Loupe settings use the LOUPE_ prefix.
#
# Default (no env at all): embedded SQLite at data/loupe.db — nothing to set.

# Dev against the docker-compose Postgres 18 (`make db-up`, host port 5433):
LOUPE_DB_DRIVER=postgres
LOUPE_DB_DSN=postgres://loupe:loupe@localhost:5433/loupe?sslmode=disable

# MySQL / MariaDB alternative:
# LOUPE_DB_DRIVER=mysql
# LOUPE_DB_DSN=loupe:loupe@tcp(localhost:3306)/loupe?parseTime=true
